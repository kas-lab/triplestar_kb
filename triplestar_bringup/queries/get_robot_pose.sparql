# Example SPARQL query: Get robot pose using query-time TF subscription
# Usage: ros2 run triplestar_core query_kb get_robot_pose.sparql
#
# This query demonstrates using custom functions for query-time data injection.
# The robotPose() function is defined in the kb_params.yaml configuration.

PREFIX ex: <http://example.org/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT ?robot ?pose
WHERE {
  ?robot rdf:type ex:Robot .
  BIND(ex:robotPose() AS ?pose)
}
