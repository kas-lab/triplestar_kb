@prefix ex:<http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .

ex:Room1 a ex:Room ;
    rdfs:label "Kitchen" ;
    geo:hasGeometry [
        a geo:Geometry ;
        geo:asWKT "POLYGON((2.328747 1.399047, 2.251106 -1.991948, -3.106546 -1.992241, -3.134026 -0.318118, -3.128059 0.462368, -3.118882 1.922936, -0.278613 2.030740, -0.279067 1.451062, 2.328747 1.399047))"^^geo:wktLiteral
    ] .


ex:Room2 a ex:Room ;
    rdfs:label "Living" ;
    geo:hasGeometry [
        a geo:Geometry ;
        geo:asWKT """POLYGON ((
            -3.233107328414917 -4.65574312210083,
            -6.657511234283447 -4.701780796051025,
            -6.622239589691162 -3.959710121154785,
            -9.414762496948242 -3.866776466369629,
            -9.385372161865234 2.0078845024108887,
            -3.172490358352661 1.9111781120300293,
            -3.233107328414917 -4.65574312210083
        ))"""^^geo:wktLiteral
    ] .

ex:Room3 a ex:Room ;
    rdfs:label "Bedroom" ;
    geo:hasGeometry [
        a geo:Geometry ;
        geo:asWKT """POLYGON ((
        -3.1521670818328857 2.000941753387451,
        0.5942485332489014 2.225738763809204,
        0.6392778754234314 3.9731006622314453,
        2.7431459426879883 3.980691432952881,
